### 3. Global Exception Handling

#### Before (Controller Advice Attributes)
```cpp
// controller/global_exception_handler.h
struct [[=novaboot::web::controller_advice{}]] GlobalExceptionHandler {
    [[=novaboot::web::exception_handler{^^examples::exception::UserNotFoundException}]]
    auto handle_user_not_found(const examples::exception::UserNotFoundException& ex, novaboot::context::RequestContext&) {
        return ResponseEntity<ErrorResponse>::status(404, {"User Not Found", ex.what()});
    }
};
```

#### After (Fluent Route Exception Handlers)
```cpp
// main.cpp (or a router configuration module)
app->router()
    .on_exception<UserNotFoundException>([](const UserNotFoundException& ex, RequestContext& ctx) {
        ErrorResponse err{"User Not Found", ex.what()};
        return ResponseEntity<ErrorResponse>::status(404, err);
    });
```

