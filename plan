### 5. Data Validation

#### Before (Field Annotations)
```cpp
struct User {
    [[=novaboot::validation::min{0}]]
    int id;

    [[=novaboot::validation::not_empty{}]]
    [[=novaboot::validation::size{.min = 2, .max = 20}]]
    std::string name;

    [[=novaboot::validation::email{}]]
    std::string email;
};
```

#### After (Validator Schema Builder)
```cpp
struct User {
    int id;
    std::string name;
    std::string email;
};

// Explicit schema configuration
inline const auto UserValidator = Validator<User>{}
    .field(&User::id, "id").min(0)
    .field(&User::name, "name").not_empty().size(2, 20)
    .field(&User::email, "email").email();
```