### 2. HTTP Routing & Controllers

#### Before (Scanning & Controller Annotations)
```cpp
// controller/user_controller.h
struct [[=novaboot::web::rest_controller{"/api/users"}]] UserController {
    UserService& user_service;

    explicit UserController(UserService& svc) : user_service(svc) {}

    [[=novaboot::web::get{""}]]
    auto list_users(novaboot::context::RequestContext& ctx) {
        return ResponseEntity<std::vector<User>>::ok(user_service.get_all_users());
    }

    [[=novaboot::web::get{"/:id"}]]
    ResponseEntity<User> get_user(int id, novaboot::context::RequestContext& ctx) {
        return ResponseEntity<User>::ok(user_service.get_user(id));
    }
};

// main.cpp
novaboot_web_register_all(*app); // Autogenerated scanner registrations
```

#### After (Fluent Route Grouping)
```cpp
// controller/user_controller.h
struct UserController {
    UserService& user_service;

    explicit UserController(UserService& svc) : user_service(svc) {}

    auto list_users(novaboot::context::RequestContext& ctx) {
        return ResponseEntity<std::vector<User>>::ok(user_service.get_all_users());
    }

    ResponseEntity<User> get_user(int id, novaboot::context::RequestContext& ctx) {
        return ResponseEntity<User>::ok(user_service.get_user(id));
    }
};

// main.cpp
app->router()
    .group("/api/users")
        .get("", di::handler<&UserController::list_users>())
        .get("/:id", di::handler<&UserController::get_user>());
```

