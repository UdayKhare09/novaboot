### 4. REST Clients

#### Before (Declarative Feign-style Interface with generated implementation)
```cpp
// client/user_service_client.h
class [[=novaboot::web::rest_client{"https://localhost:4433","http2"}]] UserServiceClient {
public:
    virtual ~UserServiceClient() = default;

    [[=novaboot::web::get{"/api/users/{id}"}]]
    virtual ResponseEntity<User> get_user(int id) = 0;
};

// Usage
auto client = RestClientFactory::make<UserServiceClient>(event_loop);
```

#### After (Explicit Builder & Plain Implementation)
```cpp
// Explicit builder for the REST client
auto rest_client = RestClient::builder()
    .base_url("https://localhost:4433")
    .protocol("http2")
    .build(event_loop);

// Standard wrapper class
class UserServiceClient {
    RestClient& client_;
public:
    explicit UserServiceClient(RestClient& client) : client_(client) {}

    ResponseEntity<User> get_user(int id) {
        return client_.get("/api/users/" + std::to_string(id)).template as<User>();
    }
};
```

